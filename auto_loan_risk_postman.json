  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://YOUR-ENDPOINT-NAME.YOUR-REGION.inference.ml.azure.com",
      "description": "Replace with your Azure ML endpoint URL (from Endpoints > Consume tab)"
    },
    {
      "key": "api_key",
      "value": "YOUR_PRIMARY_KEY_HERE",
      "description": "Replace with your Primary Key from Azure ML Endpoints > Consume tab"
