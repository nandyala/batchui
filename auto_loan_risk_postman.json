{
  "info": {
    "name": "Auto Loan Delinquency Risk API",
    "_postman_id": "auto-loan-risk-api-collection",
    "description": "Complete Postman collection for testing Azure ML Auto Loan Delinquency Prediction endpoint. Includes 8 test scenarios covering all risk tiers.",
