          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/score",
          "host": ["{{base_url}}"],
          "path": ["score"]
        },
        "description": "Deep Subprime borrower. FICO 488, $22k income, 84-month term (longest), LTV > 1 (underwater), 4 past delinquencies, very high DTI, 9-year-old van. Expected: DELINQUENT (1)."
      }
    },
    {
      "name": "7. Score - Edge Case (Young Borrower, New EV)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{api_key}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"input_data\": {\n    \"columns\": [\n      \"loan_id\",\n      \"fico_score\",\n      \"income\",\n      \"loan_amount\",\n      \"vehicle_value\",\n      \"ltv_ratio\",\n      \"loan_term\",\n      \"interest_rate\",\n      \"monthly_payment\",\n      \"dti_ratio\",\n      \"employment_length\",\n      \"employment_type\",\n      \"credit_history_length\",\n      \"num_open_accounts\",\n      \"num_delinquencies_past\",\n      \"vehicle_age\",\n      \"vehicle_type\",\n      \"state\"\n    ],\n    \"index\": [],\n    \"data\": [\n      [\n        \"AL000006\",\n        680,\n        61000,\n        45000,\n        52000,\n        0.87,\n        60,\n        7.2,\n        891.50,\n        0.18,\n        1,\n        \"Full-time\",\n        2,\n        3,\n        0,\n        0,\n        \"Sedan\",\n        \"WA\"\n      ]\n    ]\n  },\n  \"params\": {}\n}",
