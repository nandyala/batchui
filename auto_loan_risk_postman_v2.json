    {
      "name": "8. Score - Batch (5 Customers at Once)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{api_key}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"input_data\": {\n    \"columns\": [\n      \"loan_id\",\n      \"fico_score\",\n      \"income\",\n      \"loan_amount\",\n      \"vehicle_value\",\n      \"ltv_ratio\",\n      \"loan_term\",\n      \"interest_rate\",\n      \"monthly_payment\",\n      \"dti_ratio\",\n      \"employment_length\",\n      \"employment_type\",\n      \"credit_history_length\",\n      \"num_open_accounts\",\n      \"num_delinquencies_past\",\n      \"vehicle_age\",\n      \"vehicle_type\",\n      \"state\"\n    ],\n    \"index\": [],\n    \"data\": [\n      [\"AL000001\", 812, 145000, 42000, 58000, 0.72, 48, 3.9,  945.12, 0.08, 15, \"Full-time\",    18, 12, 0, 0, \"SUV\",    \"CA\"],\n      [\"AL000002\", 708,  82000, 32000, 40000, 0.80, 60, 6.5,  623.40, 0.09,  7, \"Full-time\",    10,  8, 0, 1, \"Sedan\",  \"TX\"],\n      [\"AL000003\", 641,  52000, 27000, 31000, 0.87, 72, 9.5,  499.20, 0.12,  3, \"Part-time\",     5,  5, 1, 2, \"Sedan\",  \"FL\"],\n      [\"AL000004\", 587,  34000, 26000, 28000, 0.93, 72, 14.5, 618.50, 0.22,  1, \"Part-time\",     3,  4, 2, 4, \"Truck\",  \"GA\"],\n      [\"AL000005\", 488,  22000, 19500, 18000, 1.08, 84, 21.9, 558.30, 0.31,  0, \"Self-employed\", 1,  3, 4, 9, \"Van\",    \"MI\"]\n    ]\n  },\n  \"params\": {}\n}",
          "options": { "raw": { "language": "json" } }
