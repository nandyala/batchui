{
  "info": {
    "name": "Auto Loan Delinquency Risk API v2",
    "_postman_id": "auto-loan-risk-api-v2",
    "description": "Postman collection matching exact Azure ML Studio test input schema. 18 columns: loan_id, fico_score, income, loan_amount, vehicle_value, ltv_ratio, loan_term, interest_rate, monthly_payment, dti_ratio, employment_length, employment_type, credit_history_length, num_open_accounts, num_delinquencies_past, vehicle_age, vehicle_type, state.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://YOUR-ENDPOINT-NAME.YOUR-REGION.inference.ml.azure.com",
      "description": "Replace with your Azure ML endpoint URL from Endpoints > Consume tab"
    },
    {
      "key": "api_key",
      "value": "YOUR_PRIMARY_KEY_HERE",
      "description": "Replace with your Primary Key from Azure ML Endpoints > Consume tab"
    }
  ],
  "item": [
    {
      "name": "1. Health Check - Endpoint Ping",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{api_key}}" }
        ],
        "url": {
          "raw": "{{base_url}}",
          "host": ["{{base_url}}"]
        },
        "description": "Quick ping to verify endpoint is live and API key is valid. Expected: 200 OK."
      }
    },
    {
      "name": "2. Score - Super Prime (Low Risk)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{api_key}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"input_data\": {\n    \"columns\": [\n      \"loan_id\",\n      \"fico_score\",\n      \"income\",\n      \"loan_amount\",\n      \"vehicle_value\",\n      \"ltv_ratio\",\n      \"loan_term\",\n      \"interest_rate\",\n      \"monthly_payment\",\n      \"dti_ratio\",\n      \"employment_length\",\n      \"employment_type\",\n      \"credit_history_length\",\n      \"num_open_accounts\",\n      \"num_delinquencies_past\",\n      \"vehicle_age\",\n      \"vehicle_type\",\n      \"state\"\n    ],\n    \"index\": [],\n    \"data\": [\n      [\n        \"AL000001\",\n        812,\n        145000,\n        42000,\n        58000,\n        0.72,\n        48,\n        3.9,\n        945.12,\n        0.08,\n        15,\n        \"Full-time\",\n        18,\n        12,\n        0,\n        0,\n        \"SUV\",\n        \"CA\"\n      ]\n    ]\n  },\n  \"params\": {}\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/score",
          "host": ["{{base_url}}"],
          "path": ["score"]
        },
        "description": "Super Prime borrower. FICO 812, $145k income, 48-month term, 0.72 LTV, zero delinquencies, new SUV. Expected: NOT delinquent (0)."
      }
    },
    {
